{{> header}}
  <div class="tag tag-secondary">MISSION PARTNER</div>
  <h1>Welcome to FoodRescue ❤️</h1>
  <p>Hello <span class="highlight">{{name}}</span>, we are honored to partner with your organization. Together, we can turn logistics into life-saving nutrition.</p>
  
  <div style="background-color: #ffffff; padding: 24px; border-radius: 12px; text-align: left; border: 2px dashed rgba(0, 110, 47, 0.3); margin-bottom: 24px;">
    <div style="margin-bottom: 16px;">
      <p style="font-size: 20px; font-weight: 600; color: #0b1c30; margin-bottom: 4px;">Streamlined Logistics</p>
      <p style="font-size: 14px; color: #3d4a3d; opacity: 0.7; margin-bottom: 0;">Real-time matching with nearby donors.</p>
    </div>
    <div>
      <p style="font-size: 20px; font-weight: 600; color: #0b1c30; margin-bottom: 4px;">Verified Quality</p>
      <p style="font-size: 14px; color: #3d4a3d; opacity: 0.7; margin-bottom: 0;">Strict food safety protocols on every rescue.</p>
    </div>
  </div>

  <p style="font-size: 14px; color: #3d4a3d; margin-bottom: 24px;">"Our mission is simple: Food belongs on tables, not in landfills. We're here to support your team in scaling that impact."</p>

  <a href="{{dashboardUrl}}" style="display: inline-block; padding: 16px 40px; background-color: #9d4300; color: #ffffff; font-weight: 600; text-decoration: none; border-radius: 12px; text-align: center; font-size: 16px;">Access NGO Dashboard</a>
  
  {{#if applicationId}}
  <p style="margin-top: 24px; font-size: 11px; color: #6d7b6c; text-align: center;">Application ID: {{applicationId}}</p>
  {{/if}}
{{> footer}}
