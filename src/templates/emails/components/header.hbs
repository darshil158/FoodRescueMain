    .logo { height: 96px; max-width: 100%; object-fit: contain; }
    .content { padding: 24px 40px 40px; text-align: center; }
    .tag { display: inline-block; padding: 6px 12px; background-color: #e5eeff; color: #004b1e; border-radius: 99px; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 24px; }
    .tag-primary { background-color: #e5eeff; color: #006e2f; }
    .tag-secondary { background-color: #ffdbca; color: #9d4300; }
    .tag-tertiary { background-color: #ffdad5; color: #9e4036; }
    .tag-warning { background-color: #ffdad6; color: #ba1a1a; }
    h1 { font-size: 28px; font-weight: 700; line-height: 1.3; margin-bottom: 16px; color: #0b1c30; }
    p { font-size: 16px; line-height: 1.5; color: #3d4a3d; margin-bottom: 24px; }
    .highlight { font-weight: 700; color: #0b1c30; }
  </style>
