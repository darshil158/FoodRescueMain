  <style>
    /* Base Reset */
    body, p, h1, h2, h3, h4, h5, h6 { margin: 0; padding: 0; }
    body { font-family: 'Inter', Arial, sans-serif; background-color: #f8f9ff; color: #0b1c30; -webkit-font-smoothing: antialiased; }
    .wrapper { width: 100%; table-layout: fixed; background-color: #f8f9ff; padding: 32px 0; }
